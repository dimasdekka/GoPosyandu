generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Balita {
  id                Int                 @id @default(autoincrement())
  nama              String
  tglLahir          DateTime
  jk                BalitaJK
  ibu               String
  ayah              String
  alamat            String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  pemeriksaan       PemeriksaanBalita[]

  @@map("balita")
}

enum BalitaJK {
  L
  P
}

model IbuHamil {
  id                  Int                   @id @default(autoincrement())
  nama                String
  tglLahir            DateTime
  hpht                DateTime
  suami               String
  alamat              String
  noTelepon           String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  pemeriksaan         PemeriksaanIbuHamil[]

  @@map("ibuhamil")
}

model Jadwal {
  id        Int      @id @default(autoincrement())
  tema      String
  tanggal   DateTime
  waktu     String
  lokasi    String
  status    String   @default("Akan Datang")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jadwal")
}

model Lansia {
  id                Int                 @id @default(autoincrement())
  nama              String
  umur              Int
  alamat            String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  jk                String              @default("L")
  pemeriksaan       PemeriksaanLansia[]

  @@map("lansia")
}

model PemeriksaanBalita {
  id              Int      @id @default(autoincrement())
  balitaId        Int
  tglUkur         DateTime @default(now())
  bb              Float
  tb              Float?
  lingkarKepala   Float?
  statusGizi      String
  catatanTindakan String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  balita          Balita   @relation(fields: [balitaId], references: [id], onDelete: Cascade)

  @@index([balitaId])
  @@map("pemeriksaanbalita")
}

model PemeriksaanIbuHamil {
  id             Int      @id @default(autoincrement())
  ibuHamilId     Int
  tglPeriksa     DateTime @default(now())
  usiaKandungan  Int
  tensiSistolik  Int?
  tensiDiastolik Int?
  bb             Float?
  tb             Float?
  lila           Float?
  tfu            Int?
  djj            Int?
  keluhan        String?  @db.Text
  statusRisiko   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ibuHamil       IbuHamil @relation(fields: [ibuHamilId], references: [id], onDelete: Cascade)

  @@index([ibuHamilId])
  @@map("pemeriksaanibuhamil")
}

model PemeriksaanLansia {
  id             Int      @id @default(autoincrement())
  lansiaId       Int
  tglPeriksa     DateTime @default(now())
  bb             Float?
  tb             Float?
  tensiSistolik  Int?
  tensiDiastolik Int?
  gulaDarah      Int?
  asamUrat       Float?
  kolesterol     Int?
  keluhan        String?  @db.Text
  resikoPTM      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lansia         Lansia   @relation(fields: [lansiaId], references: [id], onDelete: Cascade)

  @@index([lansiaId])
  @@map("pemeriksaanlansia")
}

model Remaja {
  id                Int                 @id @default(autoincrement())
  nama              String
  umur              Int
  jk                String
  sekolah           String
  alamat            String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  pemeriksaan       PemeriksaanRemaja[]

  @@map("remaja")
}

model PemeriksaanRemaja {
  id             Int      @id @default(autoincrement())
  remajaId       Int
  tglPeriksa     DateTime @default(now())
  bb             Float?
  tb             Float?
  tensiSistolik  Int?
  tensiDiastolik Int?
  lingkarPerut   Float?
  kadarHb        Float?
  statusGizi     String
  catatanEdukasi String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  remaja         Remaja   @relation(fields: [remajaId], references: [id], onDelete: Cascade)

  @@index([remajaId])
  @@map("pemeriksaanremaja")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  nama      String
  role      String   @default("KADER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}
