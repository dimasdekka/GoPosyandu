// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Enum Definitions
enum Role {
  ADMIN
  KADER
  PUSKESMAS
  MASYARAKAT
}

enum JenisKelamin {
  L
  P
}

// ------------------------------------
// CORE ENTITIES
// ------------------------------------

model User {
  id        Int      @id @default(autoincrement())
  nama      String
  username  String   @unique
  password  String
  role      Role     @default(KADER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Jadwal {
  id        Int      @id @default(autoincrement())
  tema      String
  tanggal   DateTime
  waktu     String
  lokasi    String
  status    String   @default("Akan Datang")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------
// SASARAN: BALITA & ANAK
// ------------------------------------

model Balita {
  id          Int      @id @default(autoincrement())
  nama        String
  tglLahir    DateTime
  jk          JenisKelamin
  ibu         String
  ayah        String
  alamat      String
  
  // Relations
  pemeriksaan PemeriksaanBalita[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PemeriksaanBalita {
  id              Int      @id @default(autoincrement())
  balitaId        Int
  balita          Balita   @relation(fields: [balitaId], references: [id], onDelete: Cascade)
  
  tglUkur         DateTime @default(now())
  bb              Float    // dalam kg
  tb              Float?   // dalam cm
  lingkarKepala   Float?   // dalam cm - deteksi stunting
  statusGizi      String   // "Baik", "Kurang", "Buruk", "Lebih"
  catatanTindakan String?  @db.Text // Vitamin A, Obat Cacing, Imunisasi, dll
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ------------------------------------
// SASARAN: IBU HAMIL & MENYUSUI
// ------------------------------------

model IbuHamil {
  id          Int      @id @default(autoincrement())
  nama        String
  tglLahir    DateTime
  hpht        DateTime
  suami       String
  alamat      String
  noTelepon   String
  
  // Relations
  pemeriksaan PemeriksaanIbuHamil[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PemeriksaanIbuHamil {
  id             Int      @id @default(autoincrement())
  ibuHamilId     Int
  ibuHamil       IbuHamil @relation(fields: [ibuHamilId], references: [id], onDelete: Cascade)
  
  tglPeriksa     DateTime @default(now())
  usiaKandungan  Int      // dalam minggu
  tensiSistolik  Int?
  tensiDiastolik Int?
  bb             Float?
  lila           Float?   // Lingkar Lengan Atas - deteksi KEK
  tfu            Int?     // Tinggi Fundus Uteri (cm)
  djj            Int?     // Denyut Jantung Janin per menit
  keluhan        String?  @db.Text
  statusRisiko   String   // "Normal", "Risiko Rendah", "Risiko Tinggi"
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ------------------------------------
// SASARAN: REMAJA
// ------------------------------------

model Remaja {
  id          Int      @id @default(autoincrement())
  nama        String
  umur        Int
  jk          String   @default("L") // "L" / "P"
  sekolah     String
  alamat      String
  
  // Relations
  pemeriksaan PemeriksaanRemaja[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PemeriksaanRemaja {
  id             Int      @id @default(autoincrement())
  remajaId       Int
  remaja         Remaja   @relation(fields: [remajaId], references: [id], onDelete: Cascade)
  
  tglPeriksa     DateTime @default(now())
  bb             Float?
  tb             Float?   // Tinggi Badan untuk IMT
  tensiSistolik  Int?
  tensiDiastolik Int?
  lingkarPerut   Float?   // cm
  kadarHb        Float?   // Hemoglobin g/dL - deteksi anemia
  statusGizi     String   // "Normal", "Kurang", "Lebih", "Anemia"
  catatanEdukasi String?  @db.Text
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ------------------------------------
// SASARAN: DEWASA & LANSIA
// ------------------------------------

model Lansia {
  id          Int      @id @default(autoincrement())
  nama        String
  umur        Int
  jk          String   @default("L") // "L" / "P"
  alamat      String
  
  // Relations
  pemeriksaan PemeriksaanLansia[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PemeriksaanLansia {
  id             Int      @id @default(autoincrement())
  lansiaId       Int
  lansia         Lansia   @relation(fields: [lansiaId], references: [id], onDelete: Cascade)
  
  tglPeriksa     DateTime @default(now())
  bb             Float?   // kg
  tb             Float?   // cm - untuk IMT
  tensiSistolik  Int?
  tensiDiastolik Int?
  gulaDarah      Int?     // mg/dL
  asamUrat       Float?   // mg/dL
  kolesterol     Int?     // mg/dL
  keluhan        String?  @db.Text
  resikoPTM      String   // "Rendah", "Sedang", "Tinggi"
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
